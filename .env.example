# Kyora IQ MCP server / gateway configuration.
# Copy to ".env" and adjust. Never commit your real .env.

# --- network ---
# 127.0.0.1 = local only (dev). 0.0.0.0 = accept outside connections (deploy).
KYORA_HOST=127.0.0.1
KYORA_PORT=8000

# --- auth ---
# Shared bearer token students include when connecting.
# Leave empty ONLY for local development (disables auth).
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(24))"
KYORA_TOKEN=

# --- rate limiting ---
# Max requests per minute per token (or per client IP if no token).
KYORA_RATE_PER_MIN=60

# --- logging ---
KYORA_LOG=info
